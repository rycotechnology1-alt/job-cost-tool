# Copy this file to `.env` at the repo root and paste your real values there.
# `.env` is gitignored in this repo.

# Keep the current runtime on SQLite unless you are intentionally running
# against the Postgres lineage store.
JOB_COST_API_DATABASE_PROVIDER=sqlite

# Neon Postgres admin / migration connection string.
# Paste the direct, non-pooled connection string here.
JOB_COST_API_POSTGRES_ADMIN_URL=

# Neon Postgres pooled application connection string.
# Paste the pooled connection string here.
JOB_COST_API_POSTGRES_POOLED_URL=

# Optional Postgres schema override for compatibility test/provisioning use.
JOB_COST_API_POSTGRES_SCHEMA=public

# Local dev/default mode keeps the current unauthenticated compatibility context.
# Hosted web/API mode should use `bearer` plus a shared signing secret.
JOB_COST_API_AUTH_MODE=local

# Shared secret used to validate hosted bearer tokens when
# `JOB_COST_API_AUTH_MODE=bearer`.
JOB_COST_API_AUTH_SECRET=

# Runtime artifact storage provider.
# Keep `local` for desktop/dev compatibility and use `vercel_blob` for hosted deployments.
JOB_COST_API_STORAGE_PROVIDER=local

# Vercel Blob read/write token for hosted shared artifact storage.
BLOB_READ_WRITE_TOKEN=
